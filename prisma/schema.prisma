generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model sagas {
  id        Int      @id @default(autoincrement())
  nome      String   @db.VarChar(255)
  descricao String?  @db.Text
  livros    livros[]

  @@map("sagas")
}

model livros {
  id                   Int                    @id @default(autoincrement())
  titulo               String                 @db.VarChar(255)
  sinopse              String?                @db.Text
  data_publicacao      DateTime?              @db.Date
  ordem_serie          Int?
  saga_id              Int?
  saga                 sagas?                 @relation(fields: [saga_id], references: [id], onDelete: SetNull)
  capitulos            capitulos[]
  personagemHistoricos personagem_historico[]

  @@map("livros")
}

model capitulos {
  id                        Int                    @id @default(autoincrement())
  livro_id                  Int
  parent_id                 Int?
  numero                    Int
  titulo                    String
  personagens_participantes Json?
  itens_participantes       Json?
  locais_participantes      Json?
  conteudo_json             Json?
  livros                    livros                 @relation(fields: [livro_id], references: [id], onDelete: Cascade)
  parent                    capitulos?             @relation("SubCapitulos", fields: [parent_id], references: [id], onDelete: Cascade)
  children                  capitulos[]            @relation("SubCapitulos")
  personagemHistoricos      personagem_historico[]

  @@index([livro_id], map: "livro_id")
  @@index([parent_id], map: "parent_id")
  @@map("capitulos")
}

model locais {
  id        Int      @id @default(autoincrement())
  nome      String   @db.VarChar(255)
  mundo     String   @db.VarChar(255)
  descricao String?  @db.Text
  imagem    String?
  criado_em DateTime @default(now())

  @@map("locais")
}

model personagens {
  id                  Int                    @id @default(autoincrement())
  nome                String
  titulo              String?
  classe              String?
  afiliacao           String?
  altura              String?
  peso                String?
  tipo_corporal       String?
  tipo_cabelo         String?
  cor_cabelo          String?
  olhos               String?
  olhos_especiais     String?
  tom_voz             String?
  traje_combate       String?                @db.Text
  traje_casual        String?                @db.Text
  armamento_principal String?
  virtude             String?
  defeito             String?
  temperamento        String?
  imagemCorpo         String?
  imagemRosto         String?
  criado_em           DateTime               @default(now())
  atualizado_em       DateTime               @updatedAt
  historicos          personagem_historico[]

  @@map("personagens")
}

model personagem_historico {
  id                    Int           @id @default(autoincrement())
  personagem_id         Int
  livro_id              Int?
  capitulo_id           Int?
  idade                 String?
  titulo                String?
  raca_id               Int
  ranque                String?
  subnivel              Int           @default(0)
  classificacao         String?
  nivel                 Int           @default(1)
  
  // Alterações de Experiência
  xpAtual               Int           @default(0) // Antigo "experiencia"
  xpProximo             Int           @default(100) // Novo campo necessário para o próximo nível
  
  qtd_treino            Int           @default(0)
  ponto_combate         Int           @default(0)
  ponto_combateAetheris Int           @default(0)
  classes               String?
  estilo_luta           String?
  maestria              String?
  elementos             Json?
  equipamento           Json?
  inventario            inventarios[]
  criado_em             DateTime      @default(now())
  
  capitulo              capitulos?    @relation(fields: [capitulo_id], references: [id])
  livro                 livros?       @relation(fields: [livro_id], references: [id])
  personagem            personagens   @relation(fields: [personagem_id], references: [id], onDelete: Cascade)
  raca                  racas         @relation(fields: [raca_id], references: [id])

  @@index([personagem_id])
  @@map("personagem_historico")
}

model inventarios {
  id           Int                  @id @default(autoincrement())
  historico_id Int
  nome         String               @db.VarChar(255)
  
  // Alteração de Tipo e Subtipo
  tipo         String?              @db.VarChar(100)
  subtipo      String?              @db.VarChar(100) // Adicionado para suportar categorias como "espada"
  
  quantidade   Decimal              @default(0.0) @db.Decimal(18, 2)
  historico    personagem_historico @relation(fields: [historico_id], references: [id], onDelete: Cascade)

  itens        itens?               @relation(fields: [itensId_item], references: [id_item])
  itensId_item Int?

  @@map("inventarios")
}

model sistemas {
  id            Int      @id @default(autoincrement())
  nome          String   @unique
  progressao    Json
  limite_bonus  Json
  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt
  racas         racas[]

  @@map("sistemas")
}

model racas {
  id         Int                    @id @default(autoincrement())
  nome       String                 @db.VarChar(80)
  base       Int
  limite     Int
  mundo      String                 @default("Geral") @db.VarChar(80)
  sistema_id Int
  criado_em  DateTime               @default(now())
  historicos personagem_historico[]
  sistema    sistemas               @relation(fields: [sistema_id], references: [id])

  @@map("racas")
}

model usuarios {
  id_usuario   Int       @id @default(autoincrement())
  login        String    @unique(map: "login") @db.VarChar(100)
  senha        String    @db.VarChar(255)
  nivel_acesso Int       @default(1)
  data_criacao DateTime? @default(now()) @db.Timestamp(0)

  @@map("usuarios")
}

model itens {
  id_item          Int      @id @default(autoincrement())
  nome             String   @db.VarChar(100)
  tipo             String   @db.VarChar(80)
  descricao        String?  @db.Text
  aparencia        String?  @db.Text
  listaHabilidades Json
  urlImagem        String?  @db.VarChar(255)
  usuarios         Json
  createdAt        DateTime @default(now())

  // ✅ ESSA LINHA É OBRIGATÓRIA para manter a relação com 'inventarios'
  inventarios inventarios[]

  @@map("itens")
}
