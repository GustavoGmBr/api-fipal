generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model blocos_texto {
  id          BigInt             @id @default(autoincrement())
  capitulo_id Int
  ordem       Int
  tipo        blocos_texto_tipo? @default(paragrafo)
  conteudo    String             @db.Text
  capitulos   capitulos          @relation(fields: [capitulo_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "blocos_texto_ibfk_1")

  @@index([capitulo_id], map: "capitulo_id")
}

model capitulos {
  id                Int                 @id @default(autoincrement())
  livro_id          Int
  numero            Int
  titulo            String?             @db.VarChar(255)
  blocos_texto      blocos_texto[]
  livros            livros              @relation(fields: [livro_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "capitulos_ibfk_1")
  personagem_ranque personagem_ranque[]

  @@index([livro_id], map: "livro_id")
}

model livros {
  id              Int         @id @default(autoincrement())
  titulo          String      @db.VarChar(255)
  sinopse         String?     @db.Text
  data_publicacao DateTime?   @db.Date
  ordem_serie     Int?
  capitulos       capitulos[]
}

model personagens {
  id                Int                 @id @default(autoincrement())
  nome              String              @db.VarChar(100)
  criado_em         DateTime?           @default(now()) @db.Timestamp(0)
  atualizado_em     DateTime?           @db.Timestamp(0)
  imagemCorpo       String?
  imagemRosto       String?
  raca_id           Int?
  titulo            String?             @db.VarChar(100)
  classe            String?             @db.VarChar(100)
  personagem_ranque personagem_ranque[]
  racas             racas?              @relation(fields: [raca_id], references: [id], map: "fk_personagem_raca")

  @@index([raca_id], map: "fk_personagem_raca_idx")
}

model racas {
  id          Int           @id @default(autoincrement())
  nome        String        @unique(map: "nome_UNIQUE") @db.VarChar(100)
  sistema     racas_sistema @default(ambos)
  base        Int
  limite      Int
  tipo        String?       @db.VarChar(100)
  criado_em   DateTime?     @default(now()) @db.Timestamp(0)
  personagens personagens[]
}

model usuarios {
  id_usuario   Int       @id @default(autoincrement())
  login        String    @unique(map: "login") @db.VarChar(100)
  senha        String    @db.VarChar(255)
  nivel_acesso Int       @default(1)
  data_criacao DateTime? @default(now()) @db.Timestamp(0)
}

model personagem_ranque {
  id            Int         @id @default(autoincrement())
  personagem_id Int
  capitulo_id   Int
  forma         String?     @db.VarChar(100)
  ranque        String      @db.VarChar(50)
  estrela       Int         @default(1)
  bonus_treino  Decimal     @default(0.00) @db.Decimal(10, 2)
  bonus_pc      Decimal     @default(0.00) @db.Decimal(10, 2)
  pc_total      Decimal     @default(0.00) @db.Decimal(15, 2)
  criado_em     DateTime?   @default(now()) @db.Timestamp(0)
  capitulos     capitulos   @relation(fields: [capitulo_id], references: [id], onDelete: Cascade, map: "fk_pr_capitulo")
  personagens   personagens @relation(fields: [personagem_id], references: [id], onDelete: Cascade, map: "fk_pr_personagem")

  @@index([capitulo_id], map: "fk_pr_capitulo")
  @@index([personagem_id], map: "fk_pr_personagem")
}

enum racas_sistema {
  ranque
  atributo
  ambos
}

enum blocos_texto_tipo {
  paragrafo
  dialogo
  pensamento
  quebra_cena
  citacao
}
