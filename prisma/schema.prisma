generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id_usuario Int     @id @default(autoincrement())
  login      String  @unique
  senha      String
  nome       String?
  foto       String?   // ← URL da foto
  nivel_acesso Int    @default(0)
  data_criacao DateTime @default(now())
}