generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model livros {
  id                   Int                    @id @default(autoincrement())
  titulo               String                 @db.VarChar(255)
  sinopse              String?                @db.Text
  data_publicacao      DateTime?              @db.Date
  ordem_serie          Int?
  capitulos            capitulos[]
  personagemHistoricos personagem_historico[]
}

model capitulos {
  id        Int    @id @default(autoincrement())
  livro_id  Int
  parent_id Int? // Null = Capítulo Pai | ID = Subcapítulo
  numero    Int
  titulo    String

  // Metadados (Participantes)
  personagens_participantes Json?
  itens_participantes       Json?
  locais_participantes      Json?

  // 🚀 O NOVO CORAÇÃO DA HISTÓRIA (Exclusivo para Subcapítulos)
  // Armazena o array de blocos (parágrafos, diálogos, etc.)
  conteudo_json Json?

  // Relações
  livros   livros      @relation(fields: [livro_id], references: [id], onDelete: Cascade)
  parent   capitulos?  @relation("SubCapitulos", fields: [parent_id], references: [id], onDelete: Cascade)
  children capitulos[] @relation("SubCapitulos")

  personagemHistoricos personagem_historico[]

  @@index([livro_id], map: "livro_id")
  @@index([parent_id], map: "parent_id")
  @@map("capitulos")
}

// ✅ Nova Tabela de Locais
model locais {
  id        Int      @id @default(autoincrement())
  nome      String   @db.VarChar(255)
  mundo     String   @db.VarChar(255)
  descricao String?  @db.Text
  imagem    String? // URL salva via FTP na pasta /locais
  criado_em DateTime @default(now())

  @@map("locais")
}

model personagens {
  id                  Int                    @id @default(autoincrement())
  nome                String
  titulo              String?
  classe              String?
  afiliacao           String?
  altura              String?
  peso                String?
  tipo_corporal       String?
  tipo_cabelo         String?
  cor_cabelo          String?
  olhos               String?
  olhos_especiais     String?
  tom_voz             String?
  traje_combate       String?                @db.Text
  traje_casual        String?                @db.Text
  armamento_principal String?
  virtude             String?
  defeito             String?
  temperamento        String?
  imagemCorpo         String?
  imagemRosto         String?
  criado_em           DateTime               @default(now())
  atualizado_em       DateTime               @updatedAt
  historicos          personagem_historico[]

  @@map("personagens")
}

model personagem_historico {
  id                    Int         @id @default(autoincrement())
  personagem_id         Int
  livro_id              Int?
  capitulo_id           Int?
  idade                 String?
  titulo                String?
  raca_id               Int
  ranque                String?
  subnivel              Int         @default(0)
  classificacao         String?
  qtd_treino            Int         @default(0)
  ponto_combate         Int         @default(0)
  ponto_combateAetheris Int         @default(0)
  classes               String?
  estilo_luta           String?
  maestria              String?
  elementos             Json?
  equipamento           Json?
  criado_em             DateTime    @default(now())
  capitulo              capitulos?  @relation(fields: [capitulo_id], references: [id])
  livro                 livros?     @relation(fields: [livro_id], references: [id])
  personagem            personagens @relation(fields: [personagem_id], references: [id], onDelete: Cascade)
  raca                  racas       @relation(fields: [raca_id], references: [id])

  @@index([personagem_id])
  @@index([capitulo_id], map: "personagem_historico_capitulo_id_fkey")
  @@index([livro_id], map: "personagem_historico_livro_id_fkey")
  @@index([raca_id], map: "personagem_historico_raca_id_fkey")
  @@map("personagem_historico")
}

model sistemas {
  id            Int      @id @default(autoincrement())
  nome          String   @unique
  progressao    Json
  limite_bonus  Json
  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt
  racas         racas[]

  @@map("sistemas")
}

model racas {
  id         Int                    @id @default(autoincrement())
  nome       String                 @db.VarChar(80)
  base       Int
  limite     Int
  mundo      String                 @default("Geral") @db.VarChar(80)
  sistema_id Int
  criado_em  DateTime               @default(now())
  historicos personagem_historico[]
  sistema    sistemas               @relation(fields: [sistema_id], references: [id])

  @@index([sistema_id], map: "racas_sistema_id_fkey")
  @@map("racas")
}

model usuarios {
  id_usuario   Int       @id @default(autoincrement())
  login        String    @unique(map: "login") @db.VarChar(100)
  senha        String    @db.VarChar(255)
  nivel_acesso Int       @default(1)
  data_criacao DateTime? @default(now()) @db.Timestamp(0)
}

model itens {
  id_item          Int      @id @default(autoincrement())
  nome             String   @db.VarChar(100)
  tipo             String   @db.VarChar(80)
  descricao        String?  @db.Text
  aparencia        String?  @db.Text
  listaHabilidades Json
  urlImagem        String?  @db.VarChar(255)
  usuarios         Json
  createdAt        DateTime @default(now())

  @@map("itens") // 👈 ISSO É VITAL: Diz ao Prisma que a tabela se chama "itens"
}
