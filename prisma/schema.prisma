generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model livros {
  id              Int         @id @default(autoincrement())
  titulo          String      @db.VarChar(255)
  sinopse         String?     @db.Text
  data_publicacao DateTime?   @db.Date
  ordem_serie     Int?
  capitulos       capitulos[]
}

model capitulos {
  id           Int            @id @default(autoincrement())
  livro_id     Int
  numero       Int
  titulo       String?        @db.VarChar(255)
  blocos_texto blocos_texto[]
  livros       livros         @relation(fields: [livro_id], references: [id], onDelete: Cascade)

  @@index([livro_id], map: "livro_id")
}

model blocos_texto {
  id          BigInt             @id @default(autoincrement())
  capitulo_id Int
  ordem       Int
  tipo        blocos_texto_tipo? @default(paragrafo)
  conteudo    String             @db.Text
  capitulos   capitulos          @relation(fields: [capitulo_id], references: [id], onDelete: Cascade)

  @@index([capitulo_id], map: "capitulo_id")
}

model personagens {
  id        Int     @id @default(autoincrement())
  nome      String
  titulo    String?
  classe    String?
  afiliacao String? // Afiliação

  // --- Atributos Físicos ---
  altura          String?
  peso            String?
  tipo_corporal   String? // Tipo Corporal
  tipo_cabelo     String? // Tipo De Cabelo
  cor_cabelo      String? // Cor do Cabelo
  olhos           String?
  olhos_especiais String? // Olhos especiais
  tom_voz         String? // Tom de voz

  // --- Estética e Equipamento ---
  traje_combate       String? @db.Text // Ex: Armadura Leve
  traje_casual        String? @db.Text // Ex: Calça e camisa social
  armamento_principal String? // Ex: Espada Pesada

  // --- Personalidade ---
  virtude      String?
  defeito      String?
  temperamento String?

  // --- Mídias ---
  imagemCorpo String?
  imagemRosto String?

  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt
  racas         racas?   @relation(fields: [racasId], references: [id])
  racasId       Int?

  @@map("personagens")
}

model sistemas {
  id            Int      @id @default(autoincrement())
  nome          String   @unique
  progressao    Json
  limite_bonus  Json
  racas         racas[]
  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  @@map("sistemas")
}

model racas {
  id     Int    @id @default(autoincrement())
  nome   String @db.VarChar(80)
  base   Int
  limite Int
  mundo  String @default("Geral") @db.VarChar(80)

  // Relação com Sistemas
  sistema_id Int
  sistema    sistemas @relation(fields: [sistema_id], references: [id])

  criado_em   DateTime      @default(now())
  personagens personagens[]

  @@map("racas")
}

model usuarios {
  id_usuario   Int       @id @default(autoincrement())
  login        String    @unique(map: "login") @db.VarChar(100)
  senha        String    @db.VarChar(255)
  nivel_acesso Int       @default(1)
  data_criacao DateTime? @default(now()) @db.Timestamp(0)
}

model itens {
  id_item          Int      @id @default(autoincrement())
  nome             String   @db.VarChar(100)
  descricao        String?  @db.Text
  aparencia        String?  @db.Text
  listaHabilidades Json
  urlImagem        String?  @db.VarChar(255)
  usuarios         Json
  createdAt        DateTime @default(now())
}

enum blocos_texto_tipo {
  paragrafo
  dialogo
  pensamento
  quebra_cena
  citacao
}
